<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
</head>

<body>
    <%- include('../partials/header') %>

        <main>
            <section class="hero">
                <div class="container hero-grid">
                    <div>
                        <span class="eyebrow">Discover • Review • Watch</span>
                        <h1>Curate Your Cinematic World.</h1>
                        <p>Discover new films, track your favorites, and create the ultimate watchlist experience.</p>
                        <div class="hero-actions" id="home-hero-actions">
                            <a id="home-movies-link" href="/movies" class="btn btn-primary">Explore Movies</a>
                            <a id="home-watchlist-link" href="/watchlist" class="btn btn-ghost">My Watchlist</a>
                        </div>
                    </div>

                    <div class="hero-panel">
                        <div>
                            <span>Latest Loaded</span>
                            <strong>
                                <%= latestMovies.length %> titles
                            </strong>
                        </div>
                        <div>
                            <span>Browse Faster</span>
                            <strong>9 latest movies</strong>
                        </div>
                        <div>
                            <span>Analytics</span>
                            <strong>Open the analytics page</strong>
                        </div>
                    </div>
                </div>
            </section>

            <section class="section">
                <div class="container">
                    <div class="section-heading">
                        <h2>Latest Movies</h2>
                        <a id="home-view-all-link" href="/movies">View all</a>
                    </div>
                    <div class="card-grid">
                        <% latestMovies.forEach((movie)=> { %>
                            <%- include('../partials/movie-card', { movie }) %>
                                <% }) %>
                    </div>
                </div>
            </section>

        </main>

        <%- include('../partials/footer') %>
</body>

</html>
