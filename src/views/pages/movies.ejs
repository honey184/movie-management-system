<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
</head>

<body>
    <%- include('../partials/header') %>

        <main class="section">
            <div class="container">
                <div class="page-top">
                    <div>
                        <span class="eyebrow">Collection</span>
                        <h1>Browse Movies</h1>
                    </div>
                </div>

                <form action="/movies" method="GET" class="filters">
                    <input type="text" name="q" placeholder="Search by title, genre, keyword" value="<%= filters.q %>">
                    <input type="text" name="genre" placeholder="Genre" value="<%= filters.genre %>">
                    <input type="number" name="releaseYear" placeholder="Release Year"
                        value="<%= filters.releaseYear %>">
                    <select name="sort">
                        <option value="" selected disabled hidden>Sort movies</option>

                        <option value="releaseYear" <%=filters.sort==='releaseYear' ? 'selected' : '' %>>
                            Oldest first
                        </option>

                        <option value="-releaseYear" <%=filters.sort==='-releaseYear' ? 'selected' : '' %>>
                            Newest first
                        </option>

                        <option value="-ratingsCount" <%=filters.sort==='-ratingsCount' ? 'selected' : '' %>>
                            Most reviewed
                        </option>
                    </select>
                    <select name="limit" onchange="this.form.submit()">
                        <option value="10" <%=pagination.limit===10 ? 'selected' : '' %>>10 per page</option>
                        <option value="20" <%=pagination.limit===20 ? 'selected' : '' %>>20 per page</option>
                        <option value="50" <%=pagination.limit===50 ? 'selected' : '' %>>50 per page</option>
                    </select>
                    <button type="submit" class="btn btn-primary">Apply</button>
                </form>

                <div class="card-grid">
                    <% if (movies.length) { %>
                        <% movies.forEach((movie)=> { %>
                            <%- include('../partials/movie-card', { movie }) %>
                                <% }) %>
                                    <% } else { %>
                                        <div class="empty-state">
                                            <h3>No movies found</h3>
                                            <p>Try a different search or filter combination.</p>
                                        </div>
                                        <% } %>
                </div>

                <div class="pagination">
                    <% if (pagination.hasPrev) { %>
                        <a class="btn btn-ghost"
                            href="/movies?<%= new URLSearchParams({ ...filters, page: pagination.page - 1 }).toString() %>">Previous</a>
                        <% } %>
                            <span>Page <%= pagination.page %></span>
                            <% if (pagination.hasNext) { %>
                                <a class="btn btn-ghost"
                                    href="/movies?<%= new URLSearchParams({ ...filters, page: pagination.page + 1 }).toString() %>">Next</a>
                                <% } %>
                </div>
                <p class="pagination-info">
                    Showing <%= (pagination.page - 1) * pagination.limit + 1 %> to
                        <%= Math.min(pagination.page * pagination.limit, data.total || data.count || movies.length) %>
                            of
                            <%= data.total || data.count || movies.length %> movies
                </p>
            </div>
        </main>

        <%- include('../partials/footer') %>
</body>

</html>