<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
</head>

<body>
    <%- include('../partials/header') %>

        <main class="section auth-section">
            <div class="container auth-shell">
                <section class="auth-copy">
                    <span class="eyebrow">Welcome Back</span>
                    <h1>Login to manage your watchlist and reviews.</h1>
                    <p>This page uses your existing `/api/auth/login` endpoint and stores the JWT in the browser.</p>
                </section>

                <section class="auth-card">
                    <form id="login-form" class="stack-form">
                        <input type="email" name="email" placeholder="Email address" required>
                        <input type="password" name="password" placeholder="Password" required>
                        <button type="submit" class="btn btn-primary">Login</button>
                        <p class="form-message" id="login-message"></p>
                    </form>
                    <p class="auth-switch">Need an account? <a href="/register">Register</a></p>
                </section>
            </div>
        </main>

        <%- include('../partials/footer') %>
            <script src="/js/auth.js"></script>
</body>

</html>