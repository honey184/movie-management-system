<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>

    <main class="section">
        <div class="container admin-shell">
            <section class="detail-panel">
                <div class="section-heading">
                    <div>
                        <span class="eyebrow">Admin Panel</span>
                        <h1>Manage Movies</h1>
                    </div>
                    <span class="admin-badge">Admin only</span>
                </div>

                <p class="lead">Use this page to add new movies to the system.</p>

                <form id="create-movie-form" class="stack-form section-top">
                    <input type="text" name="title" placeholder="Movie title" required>
                    <textarea name="description" rows="4" placeholder="Movie description"></textarea>
                    <input type="text" name="genre" placeholder="Genres separated by comma. Example: Action, Thriller" required>
                    <input type="number" name="releaseYear" placeholder="Release year" required>
                    <input type="text" name="cast" placeholder="Cast separated by comma">
                    <button type="submit" class="btn btn-primary">Add Movie</button>
                    <p class="form-message" id="admin-create-message"></p>
                </form>
            </section>

            <section class="sidebar-panel">
                <div class="section-heading">
                    <h2>Current Movies</h2>
                    <span id="admin-movie-count"><%= movies.length %> items</span>
                </div>

                <div id="admin-movie-list" class="admin-list">
                    <% movies.forEach((movie) => { %>
                        <article class="admin-item" data-movie-id="<%= movie._id %>">
                            <div>
                                <h3><%= movie.title %></h3>
                                <p><%= movie.releaseYear %> • <%= (movie.genre || []).join(', ') %></p>
                            </div>
                            <div class="admin-actions">
                                <a href="/admin/movies/<%= movie._id %>/edit" class="btn btn-ghost">Edit</a>
                                <button class="btn btn-primary admin-delete-btn" type="button" data-movie-id="<%= movie._id %>">Delete</button>
                            </div>
                        </article>
                    <% }) %>
                </div>
            </section>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="/js/admin.js"></script>
</body>
</html>
