<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/header') %>

    <main class="section">
        <div class="container admin-edit-shell">
            <section class="detail-panel">
                <div class="section-heading">
                    <div>
                        <span class="eyebrow">Admin Edit</span>
                        <h1>Edit Movie</h1>
                    </div>
                    <a href="/admin/movies" class="btn btn-ghost">Back to Admin</a>
                </div>

                <form id="edit-movie-form" class="stack-form section-top" data-movie-id="<%= movie._id %>">
                    <input type="text" name="title" value="<%= movie.title %>" placeholder="Movie title" required>
                    <textarea name="description" rows="5" placeholder="Movie description"><%= movie.description || '' %></textarea>
                    <input type="text" name="genre" value="<%= (movie.genre || []).join(', ') %>" placeholder="Genres separated by comma" required>
                    <input type="number" name="releaseYear" value="<%= movie.releaseYear %>" placeholder="Release year" required>
                    <input type="text" name="cast" value="<%= (movie.cast || []).join(', ') %>" placeholder="Cast separated by comma">
                    <button type="submit" class="btn btn-primary">Update Movie</button>
                    <p class="form-message" id="admin-edit-message"></p>
                </form>
            </section>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="/js/admin.js"></script>
</body>
</html>
