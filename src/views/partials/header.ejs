<header class="site-header">
    <div class="container nav-shell">
        <a href="/" class="brand">MovieHub</a>

        <nav class="site-nav" id="site-nav">
            <a id="home-nav-link" href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
            <a id="analytics-nav-link" href="/analytics"
                class="<%= currentPath.startsWith('/analytics') ? 'active' : '' %>">Analytics</a>
            <a id="movies-nav-link" href="/movies"
                class="<%= currentPath.startsWith('/movies') ? 'active' : '' %>">Movies</a>
            <a id="watchlist-nav-link" href="/watchlist"
                class="<%= currentPath === '/watchlist' ? 'active' : '' %>">Watchlist</a>
        </nav>

        <div class="nav-actions" id="nav-auth-actions">
            <div class="header-user hidden" id="header-user-info">
                <strong id="header-user-name"></strong>
                <span id="header-user-email"></span>
            </div>
            <a href="/login" class="btn btn-ghost">Login</a>
            <a href="/register" class="btn btn-primary">Register</a>
        </div>
    </div>
</header>
